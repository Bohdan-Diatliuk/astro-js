---
interface Props {
	step: number;
	total: number;
	label: string;
}

const { step, total, label } = Astro.props;
const percent = Math.round((step / total) * 100);
---

<div class="ml-auto flex w-full max-w-xs flex-col gap-2">
	<div class="flex items-center justify-between text-xs font-semibold uppercase tracking-wider text-ink-soft">
		<span>{label}</span>
		<span>{percent}%</span>
	</div>
	<div class="h-1.5 w-full overflow-hidden rounded-full bg-outline/50">
		<div class="h-full rounded-full bg-accent" style={`width: ${percent}%`}></div>
	</div>
</div>
